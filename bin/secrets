#!/usr/bin/env bash
# secrets — manage the age-encrypted ~/.zsh_secret using a key stored in 1Password.
#
# The age PRIVATE key lives in 1Password (op://Private/age-dotfiles-key/private-key).
# The age PUBLIC key is embedded below (it is not secret) and used to re-encrypt.
#
# Files:
#   ~/.zsh_secret            plaintext working copy (gitignored, chmod 600) — source of truth
#   <repo>/.zsh_secret.age   encrypted, committed artifact
#
# Subcommands:
#   secrets seal     re-encrypt ~/.zsh_secret -> .zsh_secret.age (no-op if unchanged)
#   secrets unseal   decrypt .zsh_secret.age -> ~/.zsh_secret (chmod 600)
#   secrets edit     unseal if needed, open $EDITOR, then seal
#   secrets key      print the age private key from 1Password (used internally)
#   secrets status   show whether plaintext and ciphertext are in sync
set -euo pipefail

AGE_PUBKEY="age1504x8qqaz2zyk5cxzaqmc6fa06j5gak4qdl44ym9dpk8x0q963pqgr6984"
OP_KEY_REF="op://Personal/age-dotfiles-key/private-key"
PLAIN="$HOME/.zsh_secret"

# Resolve the repo root containing this script (works through symlinks).
_self="${BASH_SOURCE[0]}"
while [ -L "$_self" ]; do _self="$(readlink -f "$_self")"; done
REPO="$(cd "$(dirname "$_self")/.." && pwd)"
CIPHER="$REPO/.zsh_secret.age"

die() { echo "secrets: $*" >&2; exit 1; }

need() { command -v "$1" >/dev/null 2>&1 || die "missing required command: $1"; }

# Fetch the age private key from 1Password into stdout.
_key() {
  need op
  op read "$OP_KEY_REF" 2>/dev/null || die "could not read age key from 1Password ($OP_KEY_REF). Is op signed in? Try: eval \$(op signin)"
}

cmd_key() { _key; }

cmd_seal() {
  need age
  [ -f "$PLAIN" ] || die "no plaintext at $PLAIN — nothing to seal"
  local tmp
  tmp="$(mktemp)"
  age -r "$AGE_PUBKEY" -o "$tmp" "$PLAIN"
  # Only overwrite if the decrypted content actually differs (avoids churn:
  # age output is non-deterministic, so compare plaintext, not ciphertext).
  if [ -f "$CIPHER" ] && _decrypts_equal "$CIPHER" "$PLAIN"; then
    rm -f "$tmp"
    echo "secrets: already in sync, nothing to seal"
    return 0
  fi
  mv "$tmp" "$CIPHER"
  echo "secrets: sealed $PLAIN -> $CIPHER"
}

# Does the ciphertext decrypt to exactly the given plaintext file?
_decrypts_equal() {
  local cipher="$1" plain="$2" key
  key="$(_key)"
  diff -q <(age -d -i <(printf '%s' "$key") "$cipher" 2>/dev/null) "$plain" >/dev/null 2>&1
}

cmd_unseal() {
  need age
  [ -f "$CIPHER" ] || die "no ciphertext at $CIPHER"
  local key
  key="$(_key)"
  local tmp
  tmp="$(mktemp)"
  age -d -i <(printf '%s' "$key") "$CIPHER" > "$tmp" || { rm -f "$tmp"; die "decryption failed"; }
  mv "$tmp" "$PLAIN"
  chmod 600 "$PLAIN"
  echo "secrets: unsealed $CIPHER -> $PLAIN"
}

cmd_edit() {
  [ -f "$PLAIN" ] || cmd_unseal
  "${EDITOR:-vi}" "$PLAIN"
  cmd_seal
  echo "secrets: don't forget to commit $CIPHER"
}

cmd_status() {
  echo "repo:       $REPO"
  echo "plaintext:  $PLAIN $([ -f "$PLAIN" ] && echo '(present)' || echo '(absent)')"
  echo "ciphertext: $CIPHER $([ -f "$CIPHER" ] && echo '(present)' || echo '(absent)')"
  if [ -f "$PLAIN" ] && [ -f "$CIPHER" ]; then
    if _decrypts_equal "$CIPHER" "$PLAIN"; then
      echo "sync:       IN SYNC"
    else
      echo "sync:       OUT OF SYNC (run: secrets seal)"
    fi
  fi
}

case "${1:-}" in
  seal)   cmd_seal ;;
  unseal) cmd_unseal ;;
  edit)   cmd_edit ;;
  key)    cmd_key ;;
  status) cmd_status ;;
  *) echo "usage: secrets {seal|unseal|edit|key|status}" >&2; exit 1 ;;
esac
